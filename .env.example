# Velora ID Environment Configuration
# Copy this file to .env.local for local development

# ===========================================
# HASHKEY CHAIN CONFIGURATION
# ===========================================

# HashKey Chain Testnet RPC URL
NEXT_PUBLIC_HASHKEY_RPC_URL=https://testnet.hashkeychain.io

# HashKey Chain ID (Testnet)
NEXT_PUBLIC_HASHKEY_CHAIN_ID=177

# Block Explorer URL
NEXT_PUBLIC_EXPLORER_URL=https://testnet.hashkeyscan.io

# ===========================================
# SMART CONTRACT ADDRESSES
# ===========================================

# ZK Proof Vault Contract Address (Deploy your own or use testnet address)
NEXT_PUBLIC_PROOF_VAULT_CONTRACT=0x0000000000000000000000000000000000000000

# Velora Registry Contract Address
NEXT_PUBLIC_VELORA_REGISTRY_CONTRACT=0x0000000000000000000000000000000000000000

# ===========================================
# API CONFIGURATION
# ===========================================

# Backend API URL (if using external API)
NEXT_PUBLIC_API_URL=http://localhost:3001

# API Keys (server-side only - no NEXT_PUBLIC prefix)
OPENAI_API_KEY=sk-your-openai-api-key-here

# ===========================================
# FEATURE FLAGS
# ===========================================

# Enable mock mode for hackathon demo (no real blockchain interactions)
NEXT_PUBLIC_MOCK_MODE=true

# Enable debug logging
NEXT_PUBLIC_DEBUG=false

# ===========================================
# NEXA ID CONFIGURATION
# ===========================================

# Nexa ID Provider Endpoint (mock for hackathon)
NEXT_PUBLIC_NEXA_ID_ENDPOINT=https://mock-nexa-id.velora.dev

# Nexa ID API Key
NEXA_ID_API_KEY=nexa-demo-key

# ===========================================
# NOTES FOR HACKATHON JUDGES
# ===========================================

# For the hackathon demonstration, NEXT_PUBLIC_MOCK_MODE=true
# allows the app to run without real blockchain connections.
# All proof generation, verification, and scoring work with
# simulated data to showcase the full product flow.
#
# To test with real HashKey Chain testnet:
# 1. Set NEXT_PUBLIC_MOCK_MODE=false
# 2. Deploy contracts and update addresses above
# 3. Get testnet HSK tokens from faucet
